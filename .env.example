# Anyrouter Keepalive - Configuration
# Copy this file to .env and fill in your values

# Required: Your Anyrouter API tokens (one per line)
ANYROUTER_TOKENS="sk-ant-xxx111
sk-ant-xxx222
sk-ant-xxx333"

# Optional: QQ email for report notifications (leave empty to skip email)
QQ_EMAIL="yourname@qq.com"

# Optional: QQ SMTP authorization code (not your QQ password!)
# Generate from QQ Mail -> Settings -> Account -> POP3/IMAP/SMTP service
QQ_SMTP_AUTH_CODE="your_smtp_auth_code"

# Optional overrides
# BASE_URL="https://a-ocnfniawgw.cn-shanghai.fcapp.run"
# MODEL="opus[1m]"
